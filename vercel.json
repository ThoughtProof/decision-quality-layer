{
  "buildCommand": "",
  "outputDirectory": ".",
  "rewrites": [
    { "source": "/openapi.json", "destination": "/api/openapi" },
    { "source": "/", "destination": "/api/index" },
    { "source": "/dql/(.*)", "destination": "/api/dql/$1" }
  ],
  "functions": {
    "api/dql/**/*.ts": {
      "maxDuration": 300
    }
  },
  "headers": [
    {
      "source": "/dql/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" }
      ]
    }
  ]
}
